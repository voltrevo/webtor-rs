-            assert!(exp.is_none());
-            exp = Some((lno, r.trim()));
-            let l = l.trim_end();
-            doc += l;
-        } else {
-            doc += l;
-        }
-        doc += "\n";
-    }
-    if !case.is_empty() {
-        panic!("missing final newline");
-    }
-    let (exp_lno, exp_err) = exp.expect("missing # error indication in test case");
